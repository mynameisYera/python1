# Локально: скопируйте в .env при необходимости.
# SQLAlchemy (PostgreSQL). По умолчанию совпадает с docker-compose.yml.
SQLALCHEMY_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/python1

# Продакшен (Railway / Render) — задайте в панели хостинга, не коммитьте секреты.
# DJANGO_SECRET_KEY=случайная-длинная-строка
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-app.onrender.com,.onrender.com
# DATABASE_URL=postgresql://...   (из аддона PostgreSQL; Django и SQLAlchemy подхватят)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
